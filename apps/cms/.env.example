# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/running_red

# Payload encryption key (generate a random string)
PAYLOAD_SECRET=your-secret-here

# Cloudflare R2 storage (optional for local dev — omit to use local disk)
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_ENDPOINT=
